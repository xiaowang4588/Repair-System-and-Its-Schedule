# ============================================================
#  多媒体报修系统 - 配置文件
# ============================================================
#
#  使用方法：
#    1. 复制此文件并重命名为 .env（去掉 .example 后缀）
#       命令：cp .env.example .env
#    2. 按照下方说明修改每个配置项
#    3. 保存后重启后端服务即可生效
#
#  注意事项：
#    - 每行一个配置，格式为：配置名=配置值
#    - 等号两边不要加空格
#    - 以 # 开头的行是注释，不会生效
#    - 此文件不会提交到 Git，可以放心填写真实密码
# ============================================================


# ============================================================
#  一、必填配置（第一次部署必须修改）
# ============================================================
#  以下 4 项是系统运行的基础，不改的话会有安全风险。
# ============================================================

# 【必填】服务器地址
# 学生端（手机/电脑浏览器）访问后端的完整地址
# 如果你有域名，填：https://你的域名
# 如果没有域名，填：http://你的服务器IP:5000
# 留空的话，学生端会自动使用当前网页的地址（适合前后端部署在同一台服务器的情况）
API_BASE_URL=https://your-domain.com

# 【必填】允许访问的前端地址
# 防止别人从他的网站调用你的接口（CORS 跨域限制）
# 填你的学生端访问地址和教师端访问地址，用英文逗号隔开
# 例如：ALLOWED_ORIGINS=https://你的域名,http://localhost:8080
ALLOWED_ORIGINS=https://your-domain.com,http://localhost:8080

# 【必填】加密密钥
# 用来给登录令牌签名，防止别人伪造登录身份
# 请用一个随机字符串，越长越安全（建议 64 位以上）
# 生成方法：在终端运行 python -c "import secrets; print(secrets.token_hex(32))"
# 然后把输出的字符串粘贴到这里
SECRET_KEY=CHANGE_ME_TO_A_RANDOM_SECRET

# 【必填】管理员密码
# 教师管理后台（网页端）的登录密码
# 用户名固定为 wxzx，密码在这里设置
# 首次部署后请立即登录并修改此密码
ADMIN_PASSWORD=CHANGE_ME_IMMEDIATELY


# ============================================================
#  二、学生账号配置
# ============================================================
#  管理员在后台批量创建学生账号时，使用的默认初始密码。
#  学生首次登录后可以自己修改密码。
# ============================================================

# 学生默认密码
# 新创建的学生账号的初始密码，建议告诉学生首次登录后自行修改
STUDENT_DEFAULT_PASSWORD=CHANGE_ME_IMMEDIATELY


# ============================================================
#  三、课表数据源配置
# ============================================================
#  系统需要课表数据才能查询课程和空教室。
#  有两种方式获取课表：
#    方式 A：手动上传 Excel 课表文件（推荐，简单）
#    方式 B：自动对接学校教务系统（需要学校提供接口权限）
# ============================================================

# 数据源类型，二选一：
#   excel = 手动上传 Excel 文件（在管理后台上传）
#   api   = 自动从教务系统获取（需要填写下方的教务系统配置）
DATA_SOURCE_TYPE=excel


# ============================================================
#  四、教务系统配置（仅当上方填了 api 时需要）
# ============================================================
#  如果你选择用 Excel 上传课表，下面这些全部留空即可，不用管。
#  如果要对接教务系统，需要学校信息中心提供账号权限。
# ============================================================

# 教务系统登录账号（向学校信息中心申请）
QINGGUO_USERNAME=

# 教务系统登录密码
QINGGUO_PASSWORD=

# 以下两项是备用登录方式（通过浏览器 Cookie），一般不用填
QINGGUO_WEBVPN_TOKEN=
QINGGUO_JSESSIONID=

# 学年，例如 2025 表示 2025-2026 学年
QINGGUO_XNM=2025

# 学期：12=春季学期，3=秋季学期
QINGGUO_XQM=12

# 校区 ID（不同校区不同，向学校信息中心获取）
QINGGUO_XQH_ID=


# ============================================================
#  五、HTTPS 配置（可选，强烈建议生产环境启用）
# ============================================================
#  HTTPS = 加密传输，防止数据被窃听。
#
#  如果你用宝塔面板部署，推荐这样操作：
#    1. 在宝塔面板中添加网站
#    2. 在 SSL 页签申请 Let's Encrypt 免费证书
#    3. 证书会自动配置，下面两项留空即可
#
#  如果你不用宝塔，手动配置 SSL 证书，填写证书文件路径：
#    SSL_CERTFILE=/path/to/your/cert.pem
#    SSL_KEYFILE=/path/to/your/key.pem
#
#  留空 = 不加密（仅适合本地开发测试）
# ============================================================

SSL_CERTFILE=
SSL_KEYFILE=


# ============================================================
#  六、缓存配置（一般不需要修改）
# ============================================================
#  缓存 = 把课表数据临时存在内存中，加快查询速度。
#  以下为默认值，除非你有特殊需求，否则不用改。
# ============================================================

# 缓存过期时间（单位：秒）
# 1800 秒 = 30 分钟，即每 30 分钟自动刷新一次课表数据
CACHE_TTL_SECONDS=1800

# 是否在后台自动刷新缓存（true=是，false=否）
# 开启后，缓存快过期时会自动在后台更新，用户无感知
CACHE_BACKGROUND_REFRESH=true

# 缓存过期后是否继续使用旧数据兜底（true=是，false=否）
# 开启后，即使缓存过期了，也会先返回旧数据，等后台刷新完再更新
CACHE_FALLBACK_TO_STALE=true
