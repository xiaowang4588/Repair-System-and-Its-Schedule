# ============================================================
# 复制此文件为 .env 并填写实际配置
# cp .env.example .env
# ============================================================

# ------------------------------------------------------------
# 安全配置（必填！首次部署必须修改）
# ------------------------------------------------------------
# 允许访问 API 的前端域名（逗号分隔，用于 CORS 限制）
# 生产环境必须填写你的服务器域名或 IP，否则只有本机能访问
# 例如: ALLOWED_ORIGINS=https://your-domain.com,http://106.55.154.144:5000
ALLOWED_ORIGINS=http://106.55.154.144:5000,http://localhost:8080
# 学生 Token 签名密钥（必须修改！留空则每次重启 token 全部失效）
# 生成方式：python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=123321

# 管理员初始密码（首次启动时使用，登录后请立即修改）
# 留空则自动生成随机密码（会在终端打印）
ADMIN_PASSWORD=123456

# 学生账号默认密码（新创建的学生账号的初始密码）
STUDENT_DEFAULT_PASSWORD=123456

# ------------------------------------------------------------
# 数据源配置
# ------------------------------------------------------------
# 数据源类型：excel（上传课表文件）或 api（对接教务系统）
DATA_SOURCE_TYPE=excel

# ------------------------------------------------------------
# Excel 数据源配置（DATA_SOURCE_TYPE=excel 时生效）
# ------------------------------------------------------------
EXCEL_SHEET=Sheet1

# ------------------------------------------------------------
# 青果教务系统 API 配置（DATA_SOURCE_TYPE=api 时生效）
# ------------------------------------------------------------
QINGGUO_USERNAME=
QINGGUO_PASSWORD=

QINGGUO_WEBVPN_TOKEN=
QINGGUO_JSESSIONID=

QINGGUO_XNM=2025
QINGGUO_XQM=12
QINGGUO_XQH_ID=

# ------------------------------------------------------------
# 缓存配置
# ------------------------------------------------------------
CACHE_TTL_SECONDS=1800
CACHE_BACKGROUND_REFRESH=true
CACHE_FALLBACK_TO_STALE=true
